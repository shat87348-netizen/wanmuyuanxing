{
  "openapi": "3.0.1",
  "info": {
    "title": "数据处理子系统 - 业务管理服务 (business-service)",
    "description": "提供试验任务、接口管理、告警、校准配置、可视化布局、解析模型导入导出等 REST API 与 WebSocket 推送。",
    "contact": {
      "name": "数据处理子系统团队"
    },
    "license": {
      "name": "Internal",
      "url": "https://example.com"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/",
      "description": "当前服务"
    },
    {
      "url": "http://localhost:8082",
      "description": "本地直连"
    }
  ],
  "tags": [
    {
      "name": "试验任务",
      "description": "试验任务 CRUD + 激活切换"
    },
    {
      "name": "告警入口",
      "description": "ingest-service 上行告警事件"
    },
    {
      "name": "代理注册中心",
      "description": "ingest 上行同步 + 前端查询采集代理状态"
    },
    {
      "name": "Business 基础信息",
      "description": "business-service 自描述与 ping 端点"
    },
    {
      "name": "解析模型",
      "description": "解析/布局/告警/校准 4 类配置的 CRUD 与 ZIP 导入导出"
    }
  ],
  "paths": {
    "/api/task/{id}": {
      "get": {
        "tags": [
          "试验任务"
        ],
        "summary": "查询任务详情",
        "operationId": "get",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/Task"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "试验任务"
        ],
        "summary": "更新任务（部分字段）",
        "operationId": "update",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Task"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/Task"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "试验任务"
        ],
        "summary": "删除任务",
        "operationId": "delete",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "object"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/parse-model/{taskId}": {
      "get": {
        "tags": [
          "解析模型"
        ],
        "summary": "查询某 task 的解析模型包",
        "operationId": "get_1",
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ParseModelPackage"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "解析模型"
        ],
        "summary": "整体覆盖保存（前端编辑后调用）",
        "operationId": "save",
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ParseModelPackage"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "object"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/task": {
      "get": {
        "tags": [
          "试验任务"
        ],
        "summary": "列出全部任务",
        "operationId": "list",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Task"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "试验任务"
        ],
        "summary": "新建任务",
        "operationId": "create",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Task"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/Task"
                }
              }
            }
          }
        }
      }
    },
    "/api/task/{id}/activate": {
      "post": {
        "tags": [
          "试验任务"
        ],
        "summary": "激活任务",
        "description": "前端切换当前任务上下文；其他任务自动置为未激活。",
        "operationId": "activate",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "object"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/parse-model/{taskId}/import": {
      "post": {
        "tags": [
          "解析模型"
        ],
        "summary": "导入 ZIP",
        "description": "上传由 export 产生（或同结构）的 ZIP 文件，覆盖到指定 task。",
        "operationId": "importZip",
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "required": [
                  "file"
                ],
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ParseModelPackage"
                }
              }
            }
          }
        }
      }
    },
    "/api/alarm/ingest": {
      "post": {
        "tags": [
          "告警入口"
        ],
        "summary": "接收 ingest 上行告警批次",
        "description": "广播到所有订阅 /ws/alarm 的前端连接。",
        "operationId": "ingest",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "object"
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "object"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/agent-registry/upsert": {
      "post": {
        "tags": [
          "代理注册中心"
        ],
        "summary": "上行同步 agent 注册/心跳",
        "description": "ingest-service 调用，覆盖式更新条目。",
        "operationId": "upsert",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AgentRegistryEntry"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "object"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/task/current": {
      "get": {
        "tags": [
          "试验任务"
        ],
        "summary": "查询当前激活任务",
        "description": "未激活返回 204。",
        "operationId": "current",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/Task"
                }
              }
            }
          }
        }
      }
    },
    "/api/parse-model/{taskId}/export": {
      "get": {
        "tags": [
          "解析模型"
        ],
        "summary": "导出 ZIP",
        "description": "包含 parse_model.json / vis_layout.json / alarm_rules.json / cal_config.json / meta.txt",
        "operationId": "exportZip",
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "format": "byte"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/info": {
      "get": {
        "tags": [
          "Business 基础信息"
        ],
        "summary": "服务自描述",
        "description": "返回当前 business-service 的名称、版本与时间。",
        "operationId": "info",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "object"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/agent-registry": {
      "get": {
        "tags": [
          "代理注册中心"
        ],
        "summary": "列出全部 agent",
        "description": "供前端'接口管理'页表格展示。",
        "operationId": "list_1",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AgentRegistryEntry"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/agent-registry/{agentId}": {
      "get": {
        "tags": [
          "代理注册中心"
        ],
        "summary": "查询单个 agent 详情",
        "operationId": "get_2",
        "parameters": [
          {
            "name": "agentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/AgentRegistryEntry"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "代理注册中心"
        ],
        "summary": "移除 agent（离线或下线场景）",
        "operationId": "delete_1",
        "parameters": [
          {
            "name": "agentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "object"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Task": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "任务 ID（自增）",
            "format": "int64",
            "example": 1001
          },
          "name": {
            "type": "string",
            "description": "任务名称",
            "example": "2026年Q2 联调任务"
          },
          "description": {
            "type": "string",
            "description": "任务描述"
          },
          "model": {
            "type": "string",
            "description": "型号 / 类别",
            "example": "GF-Sat-A"
          },
          "createdAt": {
            "type": "string",
            "description": "创建时间",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "description": "最近更新时间",
            "format": "date-time"
          },
          "active": {
            "type": "boolean",
            "description": "是否激活（前端默认进入此任务）"
          }
        },
        "description": "试验任务"
      },
      "ParseModelPackage": {
        "type": "object",
        "properties": {
          "taskId": {
            "type": "integer",
            "description": "试验任务 ID",
            "format": "int64"
          },
          "taskName": {
            "type": "string",
            "description": "试验任务名称（导出时回写，导入时仅作参考）"
          },
          "parseModelJson": {
            "type": "string",
            "description": "解析模型（参数列表 / 帧布局），JSON 字符串"
          },
          "visLayoutJson": {
            "type": "string",
            "description": "可视化布局（卡片位置 / 图表配置），JSON 字符串"
          },
          "alarmRulesJson": {
            "type": "string",
            "description": "告警规则（多级阈值 / 状态字 → 级别），JSON 字符串"
          },
          "calConfigJson": {
            "type": "string",
            "description": "校准配置（算法 + 参数），JSON 字符串"
          }
        },
        "description": "试验任务的解析模型包（含解析/布局/告警/校准 4 部分）"
      },
      "AgentRegistryEntry": {
        "type": "object",
        "properties": {
          "agentId": {
            "type": "string",
            "description": "Agent ID"
          },
          "version": {
            "type": "string",
            "description": "Agent 版本"
          },
          "deployForm": {
            "type": "string",
            "description": "部署形态：standalone / embedded"
          },
          "host": {
            "type": "string",
            "description": "Agent 主机/IP"
          },
          "os": {
            "type": "string",
            "description": "Agent OS"
          },
          "arch": {
            "type": "string",
            "description": "Agent CPU 架构"
          },
          "firstSeen": {
            "type": "string",
            "description": "首次注册时刻",
            "format": "date-time"
          },
          "lastHeartbeat": {
            "type": "string",
            "description": "最近心跳时刻",
            "format": "date-time"
          },
          "memUsage": {
            "type": "number",
            "description": "Agent JVM 内存使用率 0~1",
            "format": "double"
          },
          "cpuUsage": {
            "type": "number",
            "description": "Agent CPU 使用率 0~1",
            "format": "double"
          },
          "instances": {
            "type": "array",
            "description": "各采集接口实例的状态",
            "items": {
              "$ref": "#/components/schemas/InstanceStatus"
            }
          }
        },
        "description": "代理注册中心条目（business-service 视角）"
      },
      "InstanceStatus": {
        "type": "object",
        "properties": {
          "interfaceInstanceId": {
            "type": "integer",
            "description": "接口实例 ID",
            "format": "int64"
          },
          "protocol": {
            "type": "string",
            "description": "协议",
            "example": "pdxp-udp"
          },
          "state": {
            "type": "string",
            "description": "运行状态：RUNNING / STOPPED / ERROR / BLOCKED"
          },
          "rxBytes": {
            "type": "integer",
            "description": "累计接收字节数",
            "format": "int64"
          },
          "rxMessages": {
            "type": "integer",
            "description": "累计接收消息条数",
            "format": "int64"
          },
          "rxRate": {
            "type": "integer",
            "description": "瞬时流量条数/秒",
            "format": "int64"
          },
          "errorCount": {
            "type": "integer",
            "description": "近 1 分钟异常计数",
            "format": "int64"
          },
          "lastError": {
            "type": "string",
            "description": "最近一次异常描述（可为空）"
          }
        },
        "description": "单个采集接口实例的运行状态"
      }
    }
  }
}
