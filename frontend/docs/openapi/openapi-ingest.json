{
  "openapi": "3.0.1",
  "info": {
    "title": "数据处理子系统 - 数据接入服务 (ingest-service)",
    "description": "负责数据接入（HTTP / PDXP-UDP / PDXP-TCP）、解析、处理、校准、写库。",
    "contact": {
      "name": "数据处理子系统团队"
    },
    "license": {
      "name": "Internal",
      "url": "https://example.com"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/",
      "description": "当前服务"
    },
    {
      "url": "http://localhost:8081",
      "description": "本地直连"
    }
  ],
  "tags": [
    {
      "name": "Ingest 基础信息",
      "description": "ingest-service 自描述与 ping 端点"
    },
    {
      "name": "Agent 接口",
      "description": "采集代理：注册 / 心跳 / 数据上报（HTTP 兜底）"
    }
  ],
  "paths": {
    "/api/agent/report": {
      "post": {
        "tags": [
          "Agent 接口"
        ],
        "summary": "Agent 数据上报",
        "description": "兜底通道：批量上报 RawFrame；PDXP 字节直传后台。",
        "operationId": "report",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReportRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "object"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/agent/register": {
      "post": {
        "tags": [
          "Agent 接口"
        ],
        "summary": "Agent 注册",
        "description": "采集代理启动时调用，提交版本/协议/部署形态等元数据。",
        "operationId": "register",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AgentInfo"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "object"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/agent/heartbeat": {
      "post": {
        "tags": [
          "Agent 接口"
        ],
        "summary": "Agent 心跳",
        "description": "周期上报：JVM 资源、各插件实例状态/流量/异常。",
        "operationId": "heartbeat",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/HeartbeatReport"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "object"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/ingest/info": {
      "get": {
        "tags": [
          "Ingest 基础信息"
        ],
        "summary": "服务自描述",
        "description": "返回当前 ingest-service 的名称、版本与时间。",
        "operationId": "info",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "object"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "RawFrame": {
        "type": "object",
        "properties": {
          "taskId": {
            "type": "integer",
            "description": "试验任务 ID",
            "format": "int64",
            "example": 1001
          },
          "interfaceInstanceId": {
            "type": "integer",
            "description": "采集接口实例 ID（与 business-service 的 interface_instance 表对应）",
            "format": "int64",
            "example": 12
          },
          "protocol": {
            "type": "string",
            "description": "采集插件协议名，如 pdxp-udp / pdxp-tcp / http / csv",
            "example": "pdxp-udp"
          },
          "satelliteId": {
            "type": "string",
            "description": "卫星 ID（如能从协议提取）",
            "example": "SAT-007"
          },
          "payload": {
            "type": "array",
            "description": "原始字节内容（已去 TCP 转义；UDP/PDXP 单元；HTTP 时为 JSON 字节）",
            "items": {
              "type": "string",
              "description": "原始字节内容（已去 TCP 转义；UDP/PDXP 单元；HTTP 时为 JSON 字节）",
              "format": "byte"
            }
          },
          "collectTime": {
            "type": "string",
            "description": "Agent 端采集时间戳（UTC 毫秒）",
            "format": "date-time"
          },
          "agentId": {
            "type": "string",
            "description": "Agent 节点 ID",
            "example": "agent-station-A-01"
          }
        },
        "description": "采集到的原始帧（未解析）"
      },
      "ReportRequest": {
        "type": "object",
        "properties": {
          "agentId": {
            "type": "string"
          },
          "frames": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RawFrame"
            }
          }
        }
      },
      "AgentInfo": {
        "type": "object",
        "properties": {
          "agentId": {
            "type": "string",
            "description": "Agent 唯一 ID，由部署方分配",
            "example": "agent-station-A-01"
          },
          "version": {
            "type": "string",
            "description": "Agent 软件版本",
            "example": "1.0.0"
          },
          "deployForm": {
            "type": "string",
            "description": "部署形态：standalone / embedded",
            "example": "standalone"
          },
          "host": {
            "type": "string",
            "description": "Agent 部署主机名 / IP",
            "example": "10.0.0.21"
          },
          "controlPort": {
            "type": "integer",
            "description": "Agent 端 HTTP 控制端口（可选，便于后台下发命令）",
            "format": "int32",
            "example": 9090
          },
          "protocols": {
            "type": "array",
            "description": "本 Agent 启用的协议插件列表",
            "example": [
              "pdxp-udp",
              "http",
              "csv"
            ],
            "items": {
              "type": "string",
              "description": "本 Agent 启用的协议插件列表",
              "example": "[\"pdxp-udp\",\"http\",\"csv\"]"
            }
          },
          "os": {
            "type": "string",
            "description": "操作系统信息（用于诊断）",
            "example": "Linux 5.10"
          },
          "arch": {
            "type": "string",
            "description": "CPU 架构",
            "example": "x86_64"
          }
        },
        "description": "采集代理注册信息"
      },
      "HeartbeatReport": {
        "type": "object",
        "properties": {
          "agentId": {
            "type": "string",
            "description": "Agent ID",
            "example": "agent-station-A-01"
          },
          "timestamp": {
            "type": "string",
            "description": "本次心跳时刻",
            "format": "date-time"
          },
          "memUsage": {
            "type": "number",
            "description": "Agent JVM 内存使用率 0~1",
            "format": "double",
            "example": 0.42
          },
          "cpuUsage": {
            "type": "number",
            "description": "Agent CPU 使用率 0~1",
            "format": "double",
            "example": 0.31
          },
          "instances": {
            "type": "array",
            "description": "各采集插件实例的状态明细",
            "items": {
              "$ref": "#/components/schemas/InstanceStatus"
            }
          }
        },
        "description": "Agent 心跳报告"
      },
      "InstanceStatus": {
        "type": "object",
        "properties": {
          "interfaceInstanceId": {
            "type": "integer",
            "description": "接口实例 ID",
            "format": "int64"
          },
          "protocol": {
            "type": "string",
            "description": "协议",
            "example": "pdxp-udp"
          },
          "state": {
            "type": "string",
            "description": "运行状态：RUNNING / STOPPED / ERROR / BLOCKED"
          },
          "rxBytes": {
            "type": "integer",
            "description": "累计接收字节数",
            "format": "int64"
          },
          "rxMessages": {
            "type": "integer",
            "description": "累计接收消息条数",
            "format": "int64"
          },
          "rxRate": {
            "type": "integer",
            "description": "瞬时流量条数/秒",
            "format": "int64"
          },
          "errorCount": {
            "type": "integer",
            "description": "近 1 分钟异常计数",
            "format": "int64"
          },
          "lastError": {
            "type": "string",
            "description": "最近一次异常描述（可为空）"
          }
        },
        "description": "单个采集接口实例的运行状态"
      }
    }
  }
}
